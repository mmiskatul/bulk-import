# Server
HOST=0.0.0.0
PORT=8100

# Comma-separated browser/app origins that can call this API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload limit in bytes. Default is 10 MB.
MAX_UPLOAD_SIZE_BYTES=10485760

# Full multipart request limit in bytes. Default is 50 MB.
MAX_REQUEST_SIZE_BYTES=52428800

# AI normalization. The service still works without OpenAI when this is false.
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
